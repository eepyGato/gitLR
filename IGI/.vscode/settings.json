{
    "python-envs.defaultEnvManager": "ms-python.python:system",

    "files.associations": {
        "*.html": "django-html"
    },
    "emmet.includeLanguages": {
        "django-html": "html"
    },
    "[django-html]": {
        "editor.defaultFormatter": "batisteo.vscode-django"
    },
    "python.analysis.diagnosticSeverityOverrides": {
        "reportMissingModuleSource": "none"
    }
}